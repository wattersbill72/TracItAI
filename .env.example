# Neon Postgres
DATABASE_URL=                        # postgresql://... connection string

# Auth — generate with: node -e "require('crypto').randomBytes(32).toString('hex')"
JWT_SECRET=                          # 32+ byte random string
JWT_REFRESH_SECRET=                  # 32+ byte random string, DIFFERENT from JWT_SECRET

# Vercel Blob
BLOB_READ_WRITE_TOKEN=               # From Vercel dashboard

# Email (Resend)
RESEND_API_KEY=                      # From resend.com dashboard
RESEND_FROM_EMAIL=noreply@tracitai.com

# OpenAI (Whisper transcription)
OPENAI_API_KEY=

# AWS Bedrock (Nova Lite + Pro coaching AI)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-west-2
BEDROCK_MODEL_LITE=amazon.nova-lite-v1:0
BEDROCK_MODEL_PRO=amazon.nova-pro-v1:0

# Modal (CV processing — MediaPipe + TrackNet)
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
MODAL_CALLBACK_SECRET=               # Shared secret for Modal → Vercel callback auth

# Golf Intelligence API (server-side only — never expose to client)
GOLF_INTELLIGENCE_API_KEY=
GOLF_INTELLIGENCE_BASE_URL=https://api.golfintelligence.com

# App
APP_URL=https://tracitai.com         # Server-side — used in email templates and redirects
